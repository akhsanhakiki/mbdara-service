DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
PORT=3000

# Cloudflare R2 (S3 API) — product photos
# Create API token with Object Read & Write on the bucket; public URL from bucket settings (r2.dev or custom domain)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for the bucket (no trailing slash), e.g. https://pub-xxxxx.r2.dev or https://img.example.com
R2_PUBLIC_URL=
